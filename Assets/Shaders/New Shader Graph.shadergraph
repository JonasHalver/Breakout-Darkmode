{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "d9efcf74c2864e71b9493ad028c338ca",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "BoundaryRingMask (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -999.0,
            "y": -251.99998474121095,
            "width": 264.0,
            "height": 118.00001525878906
        }
    },
    "m_Slots": [
        {
            "m_Id": "2de7cd7815b64eb2bdb791f8db346e8a"
        },
        {
            "m_Id": "be7046907bef4c4ab56302dca4d14da8"
        },
        {
            "m_Id": "1b76fc00d5504010ad77ab4d114b181e"
        },
        {
            "m_Id": "d8e984a23aa34f65bfcd7214e06194d8"
        },
        {
            "m_Id": "b3b449e4b4324765b0481c74841a9ae0"
        },
        {
            "m_Id": "9f5d3e9843c94db298df14615cea2c07"
        },
        {
            "m_Id": "a238cc3f0c214a40ae0043546ae3fa9b"
        },
        {
            "m_Id": "0f3d9d7262f34230921ffc544ce95f5a"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "BoundaryRingMask",
    "m_FunctionSource": "dd1582314429a1a4f8ef1144a76dfb27",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#ifndef BOUNDARY_RING_MASK_INCLUDED\r\n#define BOUNDARY_RING_MASK_INCLUDED\r\n\r\n#define MAX_BOUNDARY_HITS 8\r\n\r\nfloat4 _BoundaryHits[MAX_BOUNDARY_HITS];\r\n// xyz = world position\r\n// w   = hit start time\r\n\r\nfloat _BoundaryHitCount;\r\nfloat _RingDuration;\r\nfloat _RingSpeed;\r\nfloat _RingWidth;\r\nfloat _RippleFrequency;\r\nfloat _RippleStrength;\r\n\r\nvoid BoundaryRingMask_float(\r\n    float3 WorldPosition,\r\n    float CurrentTime,\r\n    out float RingMask)\r\n{\r\n    RingMask = 0.0;\r\n\r\n#if defined(SHADERGRAPH_PREVIEW)\r\n    RingMask = 0.0;\r\n#else\r\n    float totalMask = 0.0;\r\n\r\n    [unroll]\r\n    for (int i = 0; i < MAX_BOUNDARY_HITS; i++)\r\n    {\r\n        if (i >= (int)_BoundaryHitCount)\r\n        {\r\n            break;\r\n        }\r\n\r\n        float4 hit = _BoundaryHits[i];\r\n\r\n        float age = CurrentTime - hit.w;\r\n\r\n        float isAlive =\r\n            step(0.0, age) *\r\n            step(age, _RingDuration);\r\n\r\n        float fade = 1.0 - saturate(age / max(_RingDuration, 0.0001));\r\n        fade *= fade;\r\n\r\n        float distanceFromHit = distance(WorldPosition.xy, hit.xy);\r\n        float radius = age * _RingSpeed;\r\n\r\n        float ringDistance = abs(distanceFromHit - radius);\r\n\r\n        float mainRing =\r\n            1.0 - smoothstep(_RingWidth, _RingWidth * 1.75, ringDistance);\r\n\r\n        float rippleWindow =\r\n            1.0 - smoothstep(_RingWidth, _RingWidth * 5.0, ringDistance);\r\n\r\n        float ripples =\r\n            sin((distanceFromHit - radius) * _RippleFrequency) * 0.5 + 0.5;\r\n\r\n        float rippleRing = ripples * rippleWindow * _RippleStrength;\r\n\r\n        float hitMask = max(mainRing, rippleRing);\r\n        hitMask *= fade;\r\n        hitMask *= isAlive;\r\n\r\n        totalMask += hitMask;\r\n    }\r\n\r\n    RingMask = saturate(totalMask);\r\n#endif\r\n}\r\n\r\n#endif"
}

